{
  "name": "roulette",
  "version": "1.0.4",
  "main": "index.ts",
  "scripts": {
    "start": "expo start --dev-client",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "windows": "npx @react-native-community/cli run-windows",
    "test:windows": "jest --config jest.config.windows.js",
    "electron:build": "expo export --platform web && electron-builder --win --x64"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/native-stack": "^7.14.11",
    "electron-serve": "^1.3.0",
    "expo": "~54.0.33",
    "expo-av": "~16.0.8",
    "expo-file-system": "^55.0.16",
    "expo-sharing": "^55.0.18",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "^5.7.0",
    "react-native-screens": "^4.24.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.0",
    "react-native-windows": "^0.81.13",
    "xlsx": "^0.18.5"
  },
  "private": true,
  "devDependencies": {
    "@react-native-windows/cli": "^0.81.5",
    "@rnx-kit/jest-preset": "^0.1.17",
    "@types/react": "^19.2.14",
    "@types/react-native": "^0.73.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "typescript": "^6.0.2"
  },
  "build": {
    "appId": "com.nex.roulette",
    "productName": "Roulette",
    "extraMetadata": {
      "main": "electron/main.js"
    },
    "directories": {
      "output": "electron-dist"
    },
    "files": [
      "electron/**/*",
      "dist/**/*"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowElevation": true
    }
  },
  "react-native-windows": {
    "init-windows": {
      "name": "roulette",
      "namespace": "roulette",
      "template": "cpp-app"
    }
  }
}
